{{!
    @template format_ucl/local/content/section/summary

    Displays the course section summary.

    Example context (json):
    {
        "hassummary": false
        "isediting": true
        "addsectiondescurl": "/course/editsection.php?id=555555&sr=5#id_summary_editor"
    }
}}
{{#hassummary}}
    {{> core_courseformat/local/content/section/summary }}
{{/hassummary}}

{{^hassummary}}
    {{#isediting}}
        <div>
            <a class="btn add-section" href="{{{addsectiondescurl}}}">
                <i class="fa-solid fa-circle-plus mr-2"></i>
                {{#str}}addsectiondescription, format_ucl{{/str}}
            </a>
        </div>
    {{/isediting}}
{{/hassummary}}
