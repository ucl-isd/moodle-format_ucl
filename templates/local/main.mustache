{{!
    @template format_ucl/local/content
    Template purpose and description.
    Classes required for JS:
    * none
    Data attributes required for JS:
    * none
    Context variables required for this template:
    * attributes Array of name / value pairs.
    Example context (json):
    {
    }
}}
{{!
  Include the core content template.
  This is the top template for a course.
}}

{{#initialsection}}
    {{> format_ucl/widgets/warnings/warnings }}
{{/initialsection}}



<div class="row p-3 px-lg-0">
    {{#toc}}
        <div class="col-lg-3 d-none d-lg-block animate-enter">
            {{> format_ucl/widgets/toc/toc }}
        </div>
    {{/toc}}

    <div id="ucl-course-content" class="col-lg-9">

        {{! Mobile toc. }}
        {{> format_ucl/widgets/toc/mobiletoc }}

        <div class="pl-lg-3">
            <div class="d-flex align-items-center">
                {{#sectionname}}
                <h2 data-region="ucl-section-name" class="ucl-section-name text-break">
                    {{{.}}}
                </h2>
                {{/sectionname}}

                {{#sectionactions}}
                    <div class="ml-auto" data-for="section-controlmenu" data-id="{{id}}">
                        {{{sectionactions}}}
                    </div>
                {{/sectionactions}}

                {{#singleedit}}
                    <div class="ml-auto">
                        <a class="btn btn-outline-secondary" href="{{{editurl}}}">
                            Edit
                        </a>
                    </div>
                {{/singleedit}}
            </div>

            {{> format_ucl/local/content }}
        </div>
    </div>
</div>
