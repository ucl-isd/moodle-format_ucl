{{!
    @template format_ucl/widgets/assessment/assessment

    Display a single assessment row with due date and activity link.

    Classes required for JS:
    * none
    Data attributes required for JS:
    * none
    Context variables required for this template:
    * duedatedate Formatted due date.
    * duedatetime Formatted due time.
    * icon Activity icon URL.
    * url Activity URL.
    * name Activity display name.
    * section Section display name.
    Example context (json):
    {
        "duedatedate": "24th Jun 2026",
        "duedatetime": "10:00am",
        "icon": "https://moodle.example/mod/assign/icon",
        "url": "https://moodle.example/mod/assign/view.php?id=123",
        "name": "Essay 1",
        "section": "Week 4"
    }
}}
<div class="col-md-4 mb-1">
    <div class="d-flex align-items-start pl-2">
        <div class="status-icon rounded-circle mr-2 d-flex flex-shrink-0 align-items-center justify-content-center">
            <i class="fa-regular fa-calendar"></i>
        </div>
        <div>
            <span class="text-muted d-md-none">{{#str}} due, format_ucl {{/str}}: </span>
            <div>{{duedatedate}}</div>
            <div class="small text-muted">{{duedatetime}}</div>
        </div>
    </div>
</div>

<div class="col-md-8">
    {{! Activity.}}
    <div class="d-flex align-items-start pl-2">
        <img src="{{icon}}" alt="" class="flex-shrink-0 mr-2" style="width: 2rem; height: 2rem;">
        <div>
            <a href="{{{url}}}" class="line-clamp-2">{{{name}}}</a>
            <small class="line-clamp-1 text-muted">{{{section}}}</small>
        </div>
    </div>
</div>
