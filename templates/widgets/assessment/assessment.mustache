 <div class="col-12 col-md-6 mb-2">
    <div class="d-flex align-items-center">
        <img src="{{icon}}" alt="" class="flex-shrink-0 mr-2" style="width: 2rem; height: 2rem;">
        <div class="mt-n3">
            <small class="line-clamp-1 text-muted">{{{section}}}</small>
            <a href="{{{url}}}">{{{name}}}</a>
        </div>
    </div>
</div>

<div class="col-12 col-md-6 mt-2">
    <div class="row">
        <div class="col-6">
            <span class="text-muted d-md-none">Due: </span> {{duedate}}
            {{! Badges }}
            {{#overdue}}
                <br><div class="badge badge-danger badge-pill">Overdue</div>
            {{/overdue}}
        </div>

       
        <div class="col text-right">
            {{! Learner data. }}
            {{#learner}}
                {{#mark}}
                    Mark: {{.}}
                {{/mark}}
                {{#submitted}}
                    <div class="badge badge-success badge-pill">Submitted</div>
                {{/submitted}}
            {{/learner}}
            
            {{! Staff data. }}
            {{#staff}}
                {{#groupmode}}
                    <div class="small">Group mode, visit the assessment for submissions.</div>
                {{/groupmode}}
                {{#hasrestrictions}}
                    <div class="small">Restricted activity, visit the assessment for submissions.</div>
                {{/hasrestrictions}}

                {{#hasstats}}
                    <div>{{submittedcount}} of {{expectedcount}}</div>
                    {{#requiremarking}}
                        <a href="{{{url}}}" class="btn btn-primary btn-sm">{{{.}}} to mark</a>
                    {{/requiremarking}}
                {{/hasstats}}
            {{/staff}}
        </div>
    </div>
</div>