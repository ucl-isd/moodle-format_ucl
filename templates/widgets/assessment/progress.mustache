<div class="d-flex justify-content-between">
    <div>
        <span class="text-muted d-md-none">Submissions: </span>
        <strong>{{submittedcount}}</strong>
        <span class="text-muted">
            {{#str}} of, mod_coursework {{/str}}
            <span>{{expectedcount}}</span>
        </span>
    </div>
    <div class="small ml-auto">
        <span>{{percent}}</span>%
    </div>
</div>

<div class="progress" style="height:.5rem;">
    <div class="progress-bar bg-success total-progress-bar"
        role="progressbar"
        aria-label="Submissions"
        aria-valuenow="{{submittedcount}}"
        style="width: {{percent}}%"
        aria-valuemin="0"
        aria-valuemax="{{expectedcount}}">
    </div>
</div>