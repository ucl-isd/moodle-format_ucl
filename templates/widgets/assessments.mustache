{{!
    @template format_ucl/widgets/assessments

    Display a list of summative assessments for the course.

    Classes required for JS:
    * none
    Data attributes required for JS:
    * none
    Context variables required for this template:
    * hasassessments Whether there are assessments to show.
    * assessments Array of assessment items.
    Example context (json):
    {
        "hasassessments": true,
        "assessments": [
            {
                "duedatedate": "24th Jun 2026",
                "duedatetime": "10:00am",
                "icon": "https://moodle.example/mod/assign/icon",
                "url": "https://moodle.example/mod/assign/view.php?id=123",
                "name": "Essay 1",
                "section": "Week 4"
            }
        ]
    }
}}
{{#hasassessments}}
<div class="py-3">
    <hr class="gr">
    <h3 class="pt-3">
        {{#str}} summativeassessments, format_ucl {{/str}}
    </h3>
    <p>{{#str}} summativeassessments:desc, format_ucl {{/str}}</p>

    {{#assessments}}
        <div class="row pt-1">
            {{> format_ucl/widgets/assessment/assessment }}
        </div>
        <hr>
    {{/assessments}}
</div>
{{/hasassessments}}
