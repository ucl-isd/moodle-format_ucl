{{!
    @template format_ucl/widgets/contacts

    Display course contacts.

    Classes required for JS:
    * none
    Data attributes required for JS:
    * none
    Context variables required for this template:
    * hascontacts Whether the course has contacts to display.
    * contacts Array of contact objects, each with properties: id, name, email, role, picture, url, description.
    * caneditroles Whether the user can edit course roles (to show edit button).
    Example context (json):
    {
        "hascontacts": true,
        "contacts": [
            {
                "id": 1,
                "name": "John Doe",
                "email": "john.doe@example.com",
                "role": "Teacher",
                "picture": "<img src='path/to/picture.jpg' alt='John Doe'>",
                "url": "/user/view.php?id=1",
                "description": "Course teacher"
            }
        ]
    }
}}

{{#hascontacts}}
<h3 class="mt-3">
    <a class="foo" data-toggle="collapse" href="#ucl-format-contacts" role="button" aria-expanded="false" aria-controls="ucl-format-contacts">
        <i class="fa-solid fa-circle-chevron-down mr-2"></i>{{#str}} coursecontacts, format_ucl {{/str}}
    </a>
</h3>

<div class="collapse pt-3" id="ucl-format-contacts">
    {{#contacts}}
    {{! Contact. }}
    <div class="d-flex align-items-start role-{{{role}}}">
        {{! Image. }}
        {{{picture}}}
        
        {{! Details. }}
        <div class="ml-2">
            <span class="badge badge-secondary badge-pill">{{{role}}}</span>
            <a href="{{{url}}}">{{{name}}}</a> · 
            <a href="mailto:{{{email}}}"><i class="fa-solid fa-envelope mr-1"></i>{{{email}}}</a>
            
            <div class="small pt-1">{{{description}}}</div>
        </div>

    </div>
    <hr>
    {{/contacts}}

    {{#caneditroles}}
    <a class="btn btn-sm btn-primary" href="{{{ config.wwwroot }}}/user/index.php?id={{courseid}}">
        {{#str}} editcourseroles, format_ucl {{/str}}
    </a>
   {{/caneditroles}}
</div>


<style>
.fa-solid  {
    transition: transform 0.5s ease;
}
.foo[aria-expanded="true"] {
    .fa-circle-chevron-down {
        transform: rotate(-180deg);
    }
}
</style>

{{/hascontacts}}
