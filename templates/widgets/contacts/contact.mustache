{{!
    @template format_ucl/widgets/contact
    Template purpose and description.
    Classes required for JS:
    * none
    Data attributes required for JS:
    * none
    Context variables required for this template:
    * attributes Array of name / value pairs.
    Example context (json):
    {
    }
}}

{{! Contact. }}
<div class="ucl-format-coursecontact d-flex align-items-start my-3" data-userid="{{id}}">

    {{! Image. }}
    <div class="flex-0 ucl-format-coursecontact-picture">{{{picture}}}</div>

    {{! Details. }}
    <div class="ml-2">
        <span class="badge badge-warning badge-pill {{#show}} d-none {{/show}}">
            <i class="fa-solid fa-eye-slash mr-1"></i>
            <span class="sr-only">{{#str}}showcontacttostudents, format_ucl{{/str}}</span>
            {{{role}}}
        </span>

        <span class="badge badge-dark badge-pill {{^show}} d-none {{/show}}">
            {{{role}}}
        </span>

        <a class="mx-1" href="{{{url}}}">{{{name}}}</a>
        {{! TODO - can we add subject or body =  course code, student number? }}
        <a href="mailto:{{{email}}}?subject=course+code" target="_blank">
            <i class="fa-regular fa-envelope mr-1"></i>{{{email}}}
        </a>

        {{#description}}
            <div class="small pt-1">{{{.}}}</div>
        {{/description}}

        {{^description}}
            {{#isediting}}
                <div class="small pt-1">
                    {{! TODO - only output if you can edit this persons course profile.}}
                    {{! TODO - add return to course? e.g. return=. }}
                    <a href="{{{ config.wwwroot }}}/user/editadvanced.php?id={{id}}&course={{courseid}}
                    #id_description_editor_label">
                    <i class="fa-solid fa-circle-plus mr-1"></i>
                    {{#str}}adddescription, format_ucl{{/str}}
                    </a>
                </div>
            {{/isediting}}
        {{/description}}

    </div>

    {{! Hide/show contact. }}
    {{#isediting}}
        {{#caneditroles}}
            <div class="ml-auto">
                <div class="custom-control custom-switch">
                    <input
                        type="checkbox" id="switch-{{id}}"
                        class="contact-hide-toggle custom-control-input"
                        data-action="{{#show}}hide{{/show}}{{^show}}show{{/show}}"
                        {{#show}} checked {{/show}}
                    >
                    <label
                        class="custom-control-label" for="switch-{{id}}"
                        title="{{#show}}{{#str}}hidefromstudents, format_ucl, {{{name}}}{{/str}}{{/show}}{{^show}}{{#str}}showtostudents, format_ucl, {{{name}}}{{/str}}{{/show}}"
                    >
                        <span class="sr-only">
                            {{#show}}{{#str}}hidefromstudents, format_ucl, {{{name}}}{{/str}}{{/show}}
                            {{^show}}{{#str}}showtostudents, format_ucl, {{{name}}}{{/str}}{{/show}}
                        </span>
                    </label>
                </div>
            </div>
        {{/caneditroles}}
    {{/isediting}}

</div>
{{#isediting}}
    <hr>
{{/isediting}}
