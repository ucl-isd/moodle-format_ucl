{{!
    @template format_ucl/widgets/contacts

    Display course contacts.

    Classes required for JS:
    * none
    Data attributes required for JS:
    * none
    Context variables required for this template:
    * hascontacts Whether the course has contacts to display.
    * contacts Array of contact objects, each with properties: id, name, email, role, picture, url, description.
    * caneditroles Whether the user can edit course roles (to show edit button).
    Example context (json):
    {
        "hascontacts": true,
        "contacts": [
            {
                "id": 1,
                "name": "John Doe",
                "email": "john.doe@example.com",
                "role": "Teacher",
                "picture": "<img src='path/to/picture.jpg' alt='John Doe'>",
                "url": "/user/view.php?id=1",
                "description": "Course teacher"
            }
        ]
    }
}}

{{#hascontacts}}
<hr>
<h3>
    <a class="foo d-flex" data-toggle="collapse" href="#ucl-format-contacts" role="button" aria-controls="ucl-format-contacts"
    {{#isediting}} aria-expanded="true" {{/isediting}}
    {{^isediting}} aria-expanded="false" {{/isediting}}>
        {{#str}} coursecontacts, format_ucl {{/str}}
        <span class="ml-auto"><i class="fa-solid fa-circle-arrow-down"></i></span>
    </a>
</h3>

<div class="collapse {{#isediting}} show {{/isediting}}" id="ucl-format-contacts">
    {{! Hide contact col label. }}
    {{! TODO - single var for isediting & caneditroles as used a lot... }}
    {{#isediting}}
    {{#caneditroles}}
    <div class="d-flex align-items-end small">
        <div>Course contacts for students.
            <br>You can hide user with a contact role you don't want to show here, but they will still be visible elsewhere in Moodle.
        </div>
        <div class="ml-auto">
            Hide contact
        </div>
    </div>
    {{/caneditroles}}
    {{/isediting}}
    
    {{#contacts}}
    {{> format_ucl/widgets/contacts/contact }}
    {{/contacts}}

    {{#isediting}}
    {{#caneditroles}}
    <div>
        <a href="{{{ config.wwwroot }}}/user/index.php?id={{courseid}}" class="btn add-section bg-white mr-3">
            <i class="fa-solid fa-circle-user mr-2"></i>
            {{#str}} editcourseroles, format_ucl {{/str}}
        </a>

        <a class="btn add-section bg-white"data-toggle="collapse" href="#ucl-format-customcontact-form" 
        role="button" aria-expanded="false" 
        aria-controls="ucl-format-customcontact-form">
            <i class="fa-solid fa-circle-plus mr-2"></i>Add custom contact
        </a>
    </div>
    {{/caneditroles}}
    {{/isediting}}

</div>

{{> format_ucl/widgets/contacts/customcontact }}

<style>
.fa-solid  {
    transition: transform 0.5s ease;
}
.foo[aria-expanded="true"] {
    .fa-circle-arrow-down {
        transform: rotate(-180deg);
    }
}

</style>
<hr>
{{/hascontacts}}
