{{!
    @template format_ucl/widgets/contacts/contacts

    Display course contacts.

    Classes required for JS:
    * none
    Data attributes required for JS:
    * none
    Context variables required for this template:
    * hascontacts Whether the course has contacts to display.
    * contacts Array of contact objects, each with properties: id, name, email, role, picture, url, description.
    * isediting Whether the user can edit course roles (to show edit button).
    Example context (json):
    {
        "hascontacts": true,
        "contacts": [
            {
                "id": 1,
                "name": "John Doe",
                "showemail": true,
                "email": "john.doe@example.com",
                "subject": "Course 1",
                "role": "Teacher",
                "picture": "<img src='path/to/picture.jpg' alt='John Doe'>",
                "url": "/user/view.php?id=1",
                "description": "Course teacher"
            }
        ]
    }
}}
{{#showcontacts}}
<div id="format-ucl-contacts-widget">
    <hr>
    {{ Contacts header. }} 
    <h3>
        <a class="d-flex" data-toggle="collapse" href="#ucl-format-contacts" role="button"
        aria-controls="ucl-format-contacts"
        {{#isediting}} aria-expanded="true" {{/isediting}}
        {{^isediting}} aria-expanded="false" {{/isediting}}>
            {{#str}} coursecontacts, format_ucl {{/str}}
            <span class="ml-auto"><i class="fa-solid fa-circle-arrow-down"></i></span>
        </a>
    </h3>

    {{ Contacts content. }} 
    <div class="collapse {{#isediting}} show {{/isediting}}" id="ucl-format-contacts">

    {{#hascontacts}}
        {{#isediting}}
        {{! Editing instructions. }}
        <div class="d-flex align-items-end small">
            <div>
                {{#str}} coursecontacts:desc, format_ucl {{/str}}
            </div>
            <div class="ml-auto">
                {{#str}} showcontact, format_ucl {{/str}}
            </div>
        </div>
        {{/isediting}}

    {{#contacts}}
    {{> format_ucl/widgets/contacts/contact }}
    {{/contacts}}

    {{#customcontacts}}
    {{> format_ucl/widgets/contacts/contact }}
    {{/customcontacts}}


    {{/hascontacts}}

    {{#isediting}}
        <div>
            <a href="{{{ config.wwwroot }}}/user/index.php?id={{courseid}}" class="btn add-section bg-white
            mr-3">
                <i class="fa-solid fa-circle-user mr-2"></i>
                {{#str}} editcourseroles, format_ucl {{/str}}
            </a>

            <a class="btn add-section bg-white" data-toggle="collapse" href="#ucl-format-customcontact-form"
            role="button" aria-expanded="false"
            aria-controls="ucl-format-customcontact-form">
                <i class="fa-solid fa-circle-plus mr-2"></i>
                {{#str}} addcustomcontact, format_ucl {{/str}}
            </a>
        </div>
        {{/isediting}}
    </div>
    <hr>
    
    {{#isediting}}
        {{> format_ucl/widgets/contacts/customcontact_form }}
    {{/isediting}}
</div>



{{#isediting}}
{{#js}}
require(['format_ucl/local/contacts'], function(component) {
    component.init({{courseid}});
});
{{/js}}
{{/isediting}}

{{/showcontacts}}
