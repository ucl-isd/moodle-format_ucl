{{!
    @template format_ucl/widgets/customcontact
    Template purpose and description.
    Classes required for JS:
    * none
    Data attributes required for JS:
    * none
    Context variables required for this template:
    * attributes Array of name / value pairs.
    Example context (json):
    {
        "contactid": 1,
        "role": "Ring Master",
        "name": "Jack Tucker",
        "email": "jtucker@stamptown.com",
        "description": "Clown master",
        "editform": "<form...>...</form>"

    }
}}
<div class="ucl-format-coursecontact d-flex align-items-start my-3">
    <div class="ml-2">{{{role}}}</div>
    <div class="ml-2">{{{name}}}</div>
    <div class="ml-2">{{{email}}}</div>
    {{#description}}
        <div class="small pt-1">{{{.}}}</div>
    {{/description}}
</div>
{{#editform}}
    {{#isediting}}
        {{#caneditroles}}
            <div>
                <a class="btn add-section bg-white" data-toggle="collapse" href="#ucl-format-customcontact-form-{{contactid}}"
                   role="button" aria-expanded="false"
                   aria-controls="ucl-format-customcontact-form">
                    <i class="fa-solid fa-circle-plus mr-2"></i>
                    {{#str}} editcustomcontact, format_ucl {{/str}}
                    <span class="sr-only">{{{name}}}</span>
                </a>
            </div>
            {{> format_ucl/widgets/contacts/editcustomcontact_form }}
        {{/caneditroles}}
    {{/isediting}}
{{/editform}}
