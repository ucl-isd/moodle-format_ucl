{{!
    @template format_ucl/widgets/contacts/customcontact_form
    Template purpose and description.
    Classes required for JS:
    * none
    Data attributes required for JS:
    * none
    Context variables required for this template:
    * contactid Optional custom contact ID suffix used to make form container IDs unique.
    * customcontactform Form render data object containing HTML.
    Example context (json):
    {
        "contactid": 10,
        "customcontactform": {
            "formhtml": "<form>...</form>"
        }
    }
}}

<div id="ucl-format-customcontact-form{{#contactid}}-{{.}}{{/contactid}}" class="collapse pt-3" >
    <div class="p-3 border">
    {{#customcontactform}}
        {{{formhtml}}}
    {{/customcontactform}}
    </div>
</div>

