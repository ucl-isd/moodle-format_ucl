{{!
    @template core_courseformat/local/content/section/sectionactions

    Displays a section control menu (dropdown menu).

    Example context (json):
    {
        "menu": "<a href=\"#\" class=\"d-inline-block dropdown-toggle icon-no-margin\">Edit<b class=\"caret\"></b></a>",
        "hasmenu": true
    }
}}
{{#hasmenu}}
    <div class="dropdown">
        <button class="btn btn-outline-secondary btn-icon dropdown-toggle rounded-circle nowt-after"
                type="button"
                id="dropdownMenuButton"
                data-toggle="dropdown"
                aria-haspopup="true"
                aria-expanded="false"
                title="edit section name">
            <i class="fa-solid fa-ellipsis-vertical"></i>
            {{! TODO }}
            <span class="sr-only"> edit section name </span>
        </button>
        <div class="dropdown-menu dropdown-menu-right"  aria-labelledby="dropdownMenuButton">
            {{#menu}}
                {{#edit}}
                    {{> format_ucl/widgets/sectionactions/sectionactions_item }}
                {{/edit}}
                {{#move}}
                    {{> format_ucl/widgets/sectionactions/sectionactions_item }}
                {{/move}}
                {{#visibility}}
                    {{> format_ucl/widgets/sectionactions/sectionactions_item }}
                {{/visibility}}
                <hr>
                {{#highlight}}
                    {{> format_ucl/widgets/sectionactions/sectionactions_item }}
                {{/highlight}}
                {{#duplicate}}
                    {{> format_ucl/widgets/sectionactions/sectionactions_item }}
                {{/duplicate}}
                {{#delete}}
                    {{> format_ucl/widgets/sectionactions/sectionactions_item }}
                {{/delete}}
            {{/menu}}
        </div>
    </div>
    <style>
        .nowt-after:after {
            display: none;
        }
    </style>
{{/hasmenu}}
