{{!
    @template core_courseformat/local/content/section/sectionactions

    Displays a section control menu (dropdown menu).

    Example context (json):
    {
        "menu": "<a href=\"#\" class=\"d-inline-block dropdown-toggle icon-no-margin\">Edit<b class=\"caret\"></b></a>",
        "hasmenu": true
    }
}}
<a
        class="dropdown-item"
        href="{{{url}}}"
        {{#data-icon}}data-icon="{{data-icon}}" {{/data-icon}}
        {{#data-sectionreturn}}data-sectionreturn="{{data-sectionreturn}}" {{/data-sectionreturn}}
        {{#data-action}}data-action="{{data-action}}"{{/data-action}}
        data-id="{{data-id}}"
        {{#data-swapname}}data-swapname="{{data-swapname}}" {{/data-swapname}}
    {{#data-swapicon}}data-swapicon="{{data-swapicon}}"{{/data-swapicon}}
    {{#hasconfirm}}
        data-confirmation="modal"
        data-confirmation-title-str='{{confirmlabel}}'
        data-confirmation-content-str='{{{confirmcontent}}}'
        data-confirmation-yes-button-str='["confirm"]'
        data-confirmation-destination="{{{url}}}"
    {{/hasconfirm}}
>
    <i class="{{iconclass}} {{icon}} mr-2"></i>
    {{name}}
</a>

