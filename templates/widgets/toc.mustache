{{!
    @template format_ucl/widgets/toc
    Template purpose and description.
    Classes required for JS:
    * none
    Data attributes required for JS:
    * none
    Context variables required for this template:
    * attributes Array of name / value pairs.
    Example context (json):
    {
    }
}}
<nav class="sticky-top" style="top: 2rem;">
    <h4>Table of contents</h4>

    <ol id="toc" class="list-unstyled pb-2">
    {{#coursesection}}
        {{> format_ucl/widgets/toc/toc_link }}
    {{/coursesection}}
    </ol>

    {{#isediting}}
      {{#addsections}}
      <div class="p-2 bg-primary-light text-center">
        <a class="btn add-section bg-white" href="{{{url}}}">
          <i class="fa-solid fa-circle-plus mr-2"></i> Add new section
        </a>
      </div>
      {{/addsections}}
    {{/isediting}}

</nav>
{{#js}}
  require(['format_ucl/local/toc'], function(component) {
        component.init('toc');
    });
{{/js}}