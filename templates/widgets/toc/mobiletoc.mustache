
<div class="d-lg-none">
    {{> format_ucl/widgets/toc/toc }}
    {{! Button trigger toc modal. }}
    <div id="mobile-toc-fab" class="d-flex position-fixed justify-content-center">
        <button type="button" class="fadeInUp btn btn-primary shadow" data-toggle="modal" data-target="#ucl-format-mobile-toc">
        <i class="fa-solid fa-bars mr-2"></i>{{#str}} toc, format_ucl {{/str}}
        </button>
    </div>

    {{! Toc modal. }}
    <div class="modal fade" id="ucl-format-mobile-toc" tabindex="-1" role="dialog" aria-labelledby="ucl-format-mobile-tocLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
        <div class="modal-header">
            <h2 class="modal-title h3" id="ucl-format-mobile-tocLabel">
                Course name
            </h2>
            <button type="button" class="close" data-dismiss="modal" aria-label="Close">
            <span aria-hidden="true">&times;</span>
            </button>
        </div>
        <div id="ucl-format-mobile-toc-body" class="modal-body">
            {{! Content gets here by js. }}
        </div>
        </div>
    </div>
    </div>
</div>

{{#js}}
require(['jquery'], function($) {
    var tocNav = document.getElementById('ucl-format-toc');
    var mobileBody = document.getElementById('ucl-format-mobile-toc-body');
    var modalElement = $('#ucl-format-mobile-toc');

    if (!tocNav || !mobileBody || !modalElement.length) {
        return;
    }

    // Capture the desktop parent immediately.
    var desktopParent = tocNav.parentElement;

    // 1. Move the Nav into the modal when it starts to open.
    modalElement.on('show.bs.modal', function() {
        mobileBody.appendChild(tocNav);
    });

    // 2. Move the Nav back to its desktop home when the modal is fully hidden.
    modalElement.on('hidden.bs.modal', function() {
        desktopParent.appendChild(tocNav);
    });

    // 3. Auto-close modal when a section is selected.
    $(tocNav).on('click', 'a', function() {
        modalElement.modal('hide');
    });
});
{{/js}}
