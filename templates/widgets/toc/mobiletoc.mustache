{{!
    @template format_ucl/widgets/toc/mobiletoc
    Template purpose and description.
    Classes required for JS:
    * none
    Data attributes required for JS:
    * none
    Context variables required for this template:
    * attributes Array of name / value pairs.
    Example context (json):
    {
    }
}}
<div class="d-lg-none">
    {{! Toc button. }}
    <div id="mobile-toc-fab">
        <button type="button" class="fadeInUp btn btn-primary shadow" data-toggle="modal" data-target="#ucl-format-mobile-toc">
        <i class="fa-solid fa-bars mr-2"></i>{{#str}} toc, format_ucl {{/str}}
        </button>
    </div>

    {{! Toc modal. }}
    <div class="modal fade" id="ucl-format-mobile-toc" tabindex="-1" role="dialog" aria-labelledby="ucl-format-mobile-toc-label" aria-hidden="true">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title h3" id="ucl-format-mobile-toc-label">
                    {{{coursename}}}
                </h2>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div id="ucl-format-mobile-toc-body" class="modal-body">
                {{! Content gets here by js. }}
            </div>
            </div>
        </div>
    </div>
</div>

{{#js}}
require(['jquery'], function($) {
    var modalElement = $('#ucl-format-mobile-toc');
    var tocNav = document.getElementById('ucl-format-toc');
    var tocBody = document.getElementById('ucl-format-mobile-toc-body');
    var tocParent = tocNav.parentElement;

    // Move Nav to modal when it starts to open.
    modalElement.on('show.bs.modal', function() {
        tocBody.appendChild(tocNav);
    });

    // Move the Nav back when the modal is hidden.
    modalElement.on('hidden.bs.modal', function() {
        tocParent.appendChild(tocNav);
    });

    // Close modal when a section is selected.
    $(tocNav).on('click', 'a', function() {
        modalElement.modal('hide');
    });
});
{{/js}}
