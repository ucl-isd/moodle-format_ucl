{{!
    @template format_ucl/widgets/toc
    Template purpose and description.
    Classes required for JS:
    * none
    Data attributes required for JS:
    * none
    Context variables required for this template:
    * attributes Array of name / value pairs.
    Example context (json):
    {
        "coursesection": [
            {
                "id": 1,
                "name": "Week 1: Introduction",
                "url": "https://www.example.com/moodle/course/view.php?id=2&section=1",
                "highlight": true,
                "visible": true,
                "active": false,
                "progress": {
                    "id": 1,
                    "total": 5,
                    "complete": 3,
                    "percentage": 60,
                    "done": false
                }
            },
            {
                "id": 2,
                "name": "Week 2: Advanced Topics",
                "url": "https://www.example.com/moodle/course/view.php?id=2&section=2",
                "highlight": false,
                "visible": true,
                "active": true,
                "progress": false
            }
        ],
        "isediting": true,
        "addsections": {
            "url": "https://www.example.com/moodle/course/changenumsections.php?courseid=2&insertsection=0&sesskey=abc123"
        }
    }
}}
<div class="sticky-top" style="top: 2rem;">
  <nav id="ucl-format-toc" aria-label="{{#str}} toc, format_ucl {{/str}}">
      <h2 class="h4">{{#str}} toc, format_ucl {{/str}}</h2>

      <ol id="toc" class="list-unstyled pb-2">
      {{#coursesection}}
          {{> format_ucl/widgets/toc/toc_link }}
      {{/coursesection}}
      </ol>

      {{#isediting}}
        {{#addsections}}
        <div class="p-2 bg-primary-light text-center">
          <a class="btn bg-white add-section behat-add-section" href="{{{url}}}">
            <i class="fa-solid fa-circle-plus mr-2"></i>
            {{#str}} addnewsection, format_ucl {{/str}}
          </a>
        </div>
        {{/addsections}}
      {{/isediting}}

  </nav>
</div>

{{#js}}
  require(['format_ucl/local/toc'], function(component) {
        component.init('toc');
    });
{{/js}}