{{!
    @template format_ucl/widgets/warnings/warnings
    Template purpose and description.
    Classes required for JS:
    * none
    Data attributes required for JS:
    * none
    Context variables required for this template:
    * attributes Array of name / value pairs.
    Example context (json):
    {
    }
}}
{{#toc}}
{{#showwarning}}
<div class="d-none d-lg-block p-3 alert alert-primary behat-ucl-tips">
    <div class="badge badge-primary">Tips</div><br>
    {{courseimage}}
    {{#shownocourseimg}}
        <div class="behat-nocourseimg">
            <b>{{#str}}nocourseimg, format_ucl{{/str}}</b>
            <p>{{#str}}nocourseimg:desc, format_ucl, {{url}}{{/str}}</p>
        </div>
    {{/shownocourseimg}}

    {{#shownunnamedsections}}
        <div class="behat-unnamedsections">
            <b><span class="behat-namecount">{{namecount}}</span> {{#str}}unnamedsections, format_ucl{{/str}}</b>
            <p>{{#str}}unnamedsections:desc, format_ucl{{/str}}</p>
        </div>
    {{/shownunnamedsections}}

    {{#showtoomanysections}}
        <div class="behat-toomanysections">
            <b>{{#str}}toomanysections, format_ucl, {{visiblecount}}{{/str}}</b>
            <p>
                {{#str}}toomanysections:pre:desc, format_ucl{{/str}}
                <span class="behat-sectioncount">{{recommendedmaxsections}}</span>
                {{#str}}toomanysections:post:desc, format_ucl, {{recommendedmaxsections}}{{/str}}
            </p>
        </div>
    {{/showtoomanysections}}

    {{#showtoofewmods}}
        <div class="behat-toofewmods">
            <b><span class="behat-modcount">{{modcount}}</span> {{#str}}toofewmods, format_ucl{{/str}}</b>
            <p>{{#str}}toofewmods:desc, format_ucl{{/str}}</p>
        </div>
    {{/showtoofewmods}}
</div>
{{/showwarning}}
{{/toc}}
